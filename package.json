{
  "icon": ".assets/icon.png",
  "publisher": "nangmanhunter-publisher",
  "repository": {
    "type": "git",
    "url": "https://github.com/nangmanhunter/text-reverse.git"
  },


  "name": "text-reverse",
  "displayName": "text-reverse",
  "description": "text-reverse",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command" : "@text-reverse/dot",
        "category": "@text-reverse/dot",
        "title"   : "."
      },
      {
        "command" : "@text-reverse/dot-middle",
        "category": "@text-reverse/dot-middle",
        "title"   : "ㆍ"
      },


      {
        "command" : "@text-reverse/hyphen",
        "category": "@text-reverse/hyphen",
        "title"   : "-"
      },
      {
        "command" : "@text-reverse/plus",
        "category": "@text-reverse/plus",
        "title"   : "+"
      },
      {
        "command" : "@text-reverse/equal",
        "category": "@text-reverse/equal",
        "title"   : "="
      },
      {
        "command" : "@text-reverse/nonequal",
        "category": "@text-reverse/nonequal",
        "title"   : "≠"
      },
      {
        "command" : "@text-reverse/space",
        "category": "@text-reverse/space",
        "title"   : "\" \""
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.125.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "esbuild": "^0.27.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
